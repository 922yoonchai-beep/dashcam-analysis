<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>行车记录仪 - 售后与运营数据分析面板</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f4f7f6; margin: 0; padding: 20px; color: #333; }
        .header { text-align: center; margin-bottom: 30px; }
        .header h1 { color: #2c3e50; }
        .container { display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; }
        .card { background: white; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); padding: 20px; width: calc(50% - 30px); min-width: 400px; box-sizing: border-box; position: relative; }
        .full-width { width: 100%; }
        .input-section { background: #fff; padding: 20px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 20px; display: flex; gap: 15px; align-items: center; justify-content: center; flex-wrap: wrap;}
        input, select, button { padding: 10px; border: 1px solid #ccc; border-radius: 4px; font-size: 14px; }
        button { background-color: #3498db; color: white; border: none; cursor: pointer; transition: 0.3s; font-weight: bold; }
        button:hover { background-color: #2980b9; }
        .export-btn { background-color: #27ae60; margin-top: 15px; width: 100%; }
        .export-btn:hover { background-color: #2ecc71; }
        canvas { max-width: 100%; background-color: white; }
    </style>
</head>
<body>

    <div class="header">
        <h1>行车记录仪数据分析面板</h1>
        <p>监控产品缺陷趋势，优化运营策略，降低差评率</p>
    </div>

    <div class="input-section">
        <strong>录入新反馈数据：</strong>
        <select id="issueType">
            <option value="死机/重启">死机/重启</option>
            <option value="夜视模糊">夜视模糊</option>
            <option value="内存卡报错">内存卡报错</option>
            <option value="支架不稳">支架不稳</option>
            <option value="漏秒/未录制">漏秒/未录制</option>
        </select>
        <input type="number" id="issueCount" placeholder="输入新增问题数量" min="1" value="1">
        <button onclick="addData()">添加到柱状图并更新</button>
    </div>

    <div class="container">
        <div class="card">
            <h3>具体问题反馈频次</h3>
            <canvas id="barChart"></canvas>
            <button class="export-btn" onclick="downloadChart('barChart', '问题反馈频次-柱状图')">💾 导出柱状图为图片</button>
        </div>

        <div class="card">
            <h3>核心差评原因占比</h3>
            <canvas id="pieChart"></canvas>
            <button class="export-btn" onclick="downloadChart('pieChart', '差评原因占比-扇形图')">💾 导出扇形图为图片</button>
        </div>

        <div class="card full-width">
            <h3>月度客诉与差评趋势</h3>
            <canvas id="lineChart"></canvas>
            <button class="export-btn" onclick="downloadChart('lineChart', '月度客诉趋势-曲线图')" style="width: auto; padding: 10px 30px; display: block; margin: 15px auto 0;">💾 导出曲线图为图片</button>
        </div>
    </div>

    <script>
        // --- 为图表添加纯白背景的插件（防止导出图片透明底变黑） ---
        const customCanvasBackgroundColor = {
            id: 'customCanvasBackgroundColor',
            beforeDraw: (chart, args, options) => {
                const {ctx} = chart;
                ctx.save();
                ctx.globalCompositeOperation = 'destination-over';
                ctx.fillStyle = options.color || '#ffffff';
                ctx.fillRect(0, 0, chart.width, chart.height);
                ctx.restore();
            }
        };

        // --- 初始化数据 ---
        const barLabels = ['死机/重启', '夜视模糊', '内存卡报错', '支架不稳', '漏秒/未录制'];
        const barData = [45, 30, 60, 15, 25];

        const pieLabels = ['硬件故障', '画质不符', '配件劣质', '软件Bug'];
        const pieData = [40, 25, 15, 20];

        const lineLabels = ['1月', '2月', '3月', '4月', '5月', '6月'];
        const lineDataSeries = [120, 105, 90, 110, 85, 70]; 

        // --- 渲染图表 ---
        const ctxBar = document.getElementById('barChart').getContext('2d');
        const barChart = new Chart(ctxBar, {
            type: 'bar',
            data: {
                labels: barLabels,
                datasets: [{ label: '问题反馈数量', data: barData, backgroundColor: 'rgba(52, 152, 219, 0.6)', borderColor: 'rgba(52, 152, 219, 1)', borderWidth: 1 }]
            },
            options: { scales: { y: { beginAtZero: true } } },
            plugins: [customCanvasBackgroundColor]
        });

        const ctxPie = document.getElementById('pieChart').getContext('2d');
        const pieChart = new Chart(ctxPie, {
            type: 'pie',
            data: {
                labels: pieLabels,
                datasets: [{ data: pieData, backgroundColor: ['#e74c3c', '#f1c40f', '#9b59b6', '#2ecc71'] }]
            },
            plugins: [customCanvasBackgroundColor]
        });

        const ctxLine = document.getElementById('lineChart').getContext('2d');
        const lineChart = new Chart(ctxLine, {
            type: 'line',
            data: {
                labels: lineLabels,
                datasets: [{ label: '每月差评及客诉总数', data: lineDataSeries, fill: false, borderColor: '#e67e22', tension: 0.1, pointBackgroundColor: '#d35400' }]
            },
            options: { scales: { y: { beginAtZero: true } } },
            plugins: [customCanvasBackgroundColor]
        });

        // --- 交互逻辑：添加新数据 ---
        function addData() {
            const type = document.getElementById('issueType').value;
            const count = parseInt(document.getElementById('issueCount').value);

            if (!count || count <= 0) {
                alert("请输入有效的数量！");
                return;
            }

            const index = barChart.data.labels.indexOf(type);
            if (index !== -1) {
                barChart.data.datasets[0].data[index] += count;
                barChart.update(); 
                
                const btn = document.querySelector('.input-section button');
                btn.innerText = "添加成功！";
                btn.style.backgroundColor = "#2ecc71";
                setTimeout(() => {
                    btn.innerText = "添加到柱状图并更新";
                    btn.style.backgroundColor = "#3498db";
                    document.getElementById('issueCount').value = 1;
                }, 1500);
            }
        }

        // --- 交互逻辑：导出图表为图片 ---
        function downloadChart(canvasId, filename) {
            const canvas = document.getElementById(canvasId);
            // 生成图片数据链接 (指定为 jpeg 格式确保底色为白，或者用 png 因为我们加了白底插件)
            const imageLink = canvas.toDataURL('image/png', 1.0);
            
            // 创建一个隐藏的下载链接并触发点击
            const link = document.createElement('a');
            link.download = filename + '.png';
            link.href = imageLink;
            link.click();
        }
    </script>
</body>
</html>